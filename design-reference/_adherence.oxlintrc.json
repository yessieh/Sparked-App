{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/EventStub/**",
              "mockups/**",
              "mockups/landings/**",
              "source/**",
              "ui_kits/mobile-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|Montserrat))/i]",
        "message": "Font not provided by the design system. Available: Inter, Montserrat."
      },
      {
        "selector": "JSXOpeningElement[name.name='EventStubEvent'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|date|time|location|tags|gradient|price|startISO|mi|saved|going|rsvps|key|ref|className|style|children)$/]",
        "message": "<EventStubEvent> doesn't accept that prop. Declared props: title, date, time, location, tags, gradient, price, startISO, mi, saved, going, rsvps."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "EventStubEvent": {
        "replaces": []
      }
    },
    "tokens": [
      "--bg-color",
      "--blur-glass",
      "--blur-overlay",
      "--blur-strong",
      "--border-soft",
      "--border-strong",
      "--bright-orange",
      "--card-bg",
      "--card-border",
      "--danger-text",
      "--deep-night",
      "--flame-red",
      "--focus-ring",
      "--font-display",
      "--font-sans",
      "--fs-body",
      "--fs-body-sm",
      "--fs-caption",
      "--fs-display",
      "--fs-eyebrow",
      "--fs-h1",
      "--fs-h2",
      "--fs-h3",
      "--fs-tick",
